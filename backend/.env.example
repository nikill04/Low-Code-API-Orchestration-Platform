# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=8h

# Default admin (created on first boot if no users exist)
DEFAULT_ADMIN_EMAIL=admin@orchestrator.dev
DEFAULT_ADMIN_PASSWORD=Admin@123

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Mock vendor behaviour (used to demonstrate retries/failures)
MOCK_VENDOR_FAILURE_RATE=0.15
MOCK_VENDOR_MIN_LATENCY_MS=150
MOCK_VENDOR_MAX_LATENCY_MS=600

# AI Agent - optional. If not set, the agent falls back to a
# rule-based generator so the feature still works out of the box.
# ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-4-6

GROQ_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
