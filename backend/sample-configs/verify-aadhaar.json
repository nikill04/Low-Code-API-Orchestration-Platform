{
  "slug": "verify-aadhaar",
  "method": "POST",
  "description": "Validates an Aadhaar number and returns a masked, normalised result.",
  "auth": { "type": "none" },
  "successStatus": 200,
  "debug": false,
  "inputSchema": {
    "body": {
      "aadhaar": { "type": "string", "required": true, "minLength": 12, "maxLength": 14 }
    }
  },
  "steps": [
    {
      "id": "validateAadhaar",
      "type": "http",
      "request": {
        "method": "POST",
        "url": "http://localhost:4000/mock/aadhaar/validate",
        "body": { "aadhaar_number": "{{input.body.aadhaar}}" }
      },
      "retry": { "maxAttempts": 3, "backoffMs": 300 }
    },
    {
      "id": "maskedAadhaar",
      "type": "transform",
      "plugin": "formatters",
      "fn": "maskAadhaar",
      "input": "{{input.body.aadhaar}}"
    }
  ],
  "response": {
    "valid": "{{steps.validateAadhaar.response.data.valid}}",
    "state": "{{steps.validateAadhaar.response.data.state}}",
    "aadhaar_masked": "{{steps.maskedAadhaar.output}}"
  }
}
